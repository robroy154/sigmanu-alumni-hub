# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/*.log

# env files
.env*
!.env.example

# vercel
.vercel

# Supabase
supabase/.branches
supabase/.temp

# Auto-generated Supabase types — regenerate with: npm run db:types
# src/types/supabase.ts  ← committed so Vercel can build without credentials

# typescript
*.tsbuildinfo
next-env.d.ts
logs/xvba_debug.log
logs/xvba_debug.log
