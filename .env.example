# =============================================================
# Sigma Nu Alumni Hub — Environment Variable Reference
# Copy this file to .env.local and fill in real values.
# This file IS committed to git (no secrets here).
# =============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Places (optional) ---
# Enables address autocomplete on signup and profile edit.
# Without this, the street address field works as a plain text input.
# Get a key at https://console.cloud.google.com — enable the "Places API".
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=re_your-key-here
# Optional — defaults to onboarding@resend.dev if unset (works without DNS setup).
RESEND_FROM_EMAIL=notifications@yourdomain.com

# --- OAuth (optional) ---
# Google OAuth button is ON by default. Set to "false" to hide the button.
# Set FACEBOOK/APPLE to "true" to show those OAuth buttons.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
NEXT_PUBLIC_FACEBOOK_OAUTH_ENABLED=false
NEXT_PUBLIC_APPLE_OAUTH_ENABLED=false

# --- Referral / Invite System ---
# Shown on expired and invalid invite error pages as a contact address.
# If unset, the mailto link is hidden.
CHAPTER_CONTACT_EMAIL=

# --- Social Links (optional) ---
# Shown on the authenticated homepage quick-links sidebar.
# If unset, the links are hidden.
NEXT_PUBLIC_ALUMNI_FB_URL=
NEXT_PUBLIC_ACTIVE_CHAPTER_FB_URL=

# --- Landing Page (optional) ---
# Full URL to a background image for the hero section on the public landing page.
# If unset, the hero renders with a solid black background (no broken layout).
# Recommended: a high-resolution chapter photo, at least 1920×1080.
NEXT_PUBLIC_HERO_IMAGE_URL=
